exports[`emitProcessPack > every emitted text file matches its snapshot > manifest/metrics.json 1`] = `
"{
  "ctqs": [
    {
      "id": "ctq1",
      "persona": "factory operator",
      "metric": "spec-approval gate compliance",
      "specLimit": "100% of emitted packs trace to an operator-approved spec",
      "defectDefinition": "an emitted pack whose spec has no recorded operator approval"
    },
    {
      "id": "ctq2",
      "persona": "pack reviewer",
      "metric": "pack gate pass rate",
      "specLimit": "every deployed pack passes mechanical validators before its draft PR opens",
      "defectDefinition": "a draft PR opened from a pack that failed a mechanical validator or lacks its metrics manifest"
    },
    {
      "id": "ctq3",
      "persona": "factory operator",
      "metric": "scan cadence",
      "specLimit": "every registry entry is scanned at least once per declared cadence window",
      "defectDefinition": "a registry entry with no scan record inside its cadence window"
    }
  ],
  "baseline": "unmeasured",
  "decisionRule": "If any CTQ records a defect in a scan window, file an improvement proposal in the needs-review queue; two consecutive defective windows escalate to the operator.",
  "controlPlan": {
    "monitoringCadence": "every factory scan run, at least once per week",
    "response": "file an improvement proposal for operator review; never auto-apply"
  },
  "governancePhase": "shadow",
  "knobs": [
    {
      "name": "scanMinSampleSize",
      "purpose": "Minimum outcome records required before a scan may file an improvement proposal — the factory refuses to propose from noise.",
      "range": {
        "min": 10,
        "max": 100
      },
      "default": 20
    }
  ]
}
"
`;

